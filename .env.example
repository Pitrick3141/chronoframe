# Required Worker secrets. Generate independent high-entropy session/bootstrap
# values with at least 32 characters; use Cloudflare's returned Stream webhook
# secret. Set production with:
#   pnpm exec wrangler secret put NUXT_SESSION_PASSWORD
#   pnpm exec wrangler secret put CFRAME_BOOTSTRAP_TOKEN
#   pnpm exec wrangler secret put CFRAME_STREAM_WEBHOOK_SECRET
# For local `wrangler dev`, put the value in the ignored `.dev.vars` file.
NUXT_SESSION_PASSWORD=
CFRAME_BOOTSTRAP_TOKEN=
# Copy the `result.secret` returned when the Stream webhook subscription is
# created. Never generate or rotate this value independently of Cloudflare.
CFRAME_STREAM_WEBHOOK_SECRET=

# Cloudflare Worker resource bindings are declared in wrangler.jsonc:
# DB (D1), IMAGES (Hosted Images), STREAM (Cloudflare Stream),
# MEDIA_BUCKET (R2 for other objects), and ASSETS.
# Do not put resource IDs or production secrets in this file. For local
# `wrangler dev`, copy private values to an ignored .dev.vars file.

# Site configuration
NUXT_PUBLIC_APP_TITLE=ChronoFrame
NUXT_PUBLIC_APP_SLOGAN=Mems rest within the lens.
NUXT_PUBLIC_APP_AUTHOR=
NUXT_PUBLIC_APP_AVATAR_URL=

# Map Provider (mapbox/maplibre)
NUXT_PUBLIC_MAP_PROVIDER=maplibre
# Map style URL
NUXT_PUBLIC_MAP_MAPLIBRE_STYLE=
NUXT_PUBLIC_MAP_MAPBOX_STYLE=
# Mapbox access token for map features, Mapbox GL JS (Client-side, public)
NUXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Mapbox secret access token for server-side, Mapbox Search API (Reverse Geocoding)
NUXT_MAPBOX_ACCESS_TOKEN=

# Custom Nominatim API base URL (use MapBox or proxy when official API is blocked in mainland China)
NUXT_NOMINATIM_BASE_URL=

# GitHub OAuth app credentials
NUXT_PUBLIC_OAUTH_GITHUB_ENABLED=false
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

# Google Analytics Measurement ID (e.g. G-XXXXXXX)
NUXT_PUBLIC_GTAG_ID=
# Matomo Analytics configuration
NUXT_PUBLIC_ANALYTICS_MATOMO_ENABLED=false
NUXT_PUBLIC_ANALYTICS_MATOMO_URL=
NUXT_PUBLIC_ANALYTICS_MATOMO_SITE_ID=

# -----------------
# Upload Configuration
# -----------------
# Cloudflare Hosted Images has a hard 10 MiB source-image limit.
NUXT_PUBLIC_CLOUDFLARE_IMAGES_MAX_UPLOAD_BYTES=10485760
# Stream basic direct uploads must be smaller than 200 MB (199999999 bytes).
NUXT_PUBLIC_CLOUDFLARE_STREAM_MAX_UPLOAD_BYTES=199999999
# Reject videos longer than 10 minutes; this is enforced server-side.
NUXT_CLOUDFLARE_STREAM_MAX_DURATION_SECONDS=600
# Raw R2 uploads traverse the Worker; this fits the Free/Pro 100 MB body limit.
NUXT_PUBLIC_CLOUDFLARE_R2_MAX_OBJECT_BYTES=100000000

# Enable MIME type whitelist validation for file uploads (default: true)
NUXT_UPLOAD_MIME_WHITELIST_ENABLED=true

# Comma-separated list of allowed MIME types for uploads
# Default includes Hosted Images inputs plus MOV/MP4 videos stored in Stream.
NUXT_UPLOAD_MIME_WHITELIST=image/jpeg,image/png,image/webp,image/gif,image/svg+xml,image/heic,image/heif,video/quicktime,video/mp4

# To disable whitelist and allow any file type, set:
# NUXT_UPLOAD_MIME_WHITELIST_ENABLED=false


# Duplicate file handling has been moved to System Settings page.
# Configure it in Dashboard -> Settings -> System:
# - Detect duplicate files on upload (enabled/disabled)
# - Duplicate file handling mode (skip/warn/block)
